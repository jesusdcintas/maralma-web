---
import "../../styles/global.css";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />
    <title>Iniciar sesión · Maralma</title>
  </head>
  <body>
    <div class="login-wrap">
      <div class="login-container">
        <div class="login-header">
          <img src="/img/logo-azul-h.png" alt="Maralma" class="login-logo" />
          <p class="login-sub">Inicia sesión para acceder al panel de administración.</p>
        </div>

        <form id="login-form" class="login-form">
          <div class="form-group">
            <label for="admin-email">Email</label>
            <input type="email" id="admin-email" required placeholder="admin@maralma.catering" />
          </div>
          <div class="form-group">
            <label for="admin-password">Contraseña</label>
            <input type="password" id="admin-password" required />
          </div>
          <button type="submit" class="btn-submit" id="submitBtn">Iniciar sesión</button>
          <div id="login-message" class="login-msg hidden"></div>
        </form>
      </div>
    </div>
  </body>
</html>

<style>
  body { margin: 0; }
  .login-wrap {
    min-height: 100vh; display: flex; align-items: center; justify-content: center;
    background: var(--color-crema); padding: 24px;
  }
  .login-container {
    max-width: 400px; width: 100%;
    background: var(--color-blanco); padding: 48px 40px;
    border: 0.5px solid var(--color-crema-oscuro);
  }
  .login-header { text-align: center; margin-bottom: 36px; }
  .login-logo { height: 28px; margin-bottom: 16px; }
  .login-sub { font-size: 13px; color: var(--color-texto-suave); font-weight: 300; font-family: var(--font-sans); }

  .login-form { display: flex; flex-direction: column; gap: 20px; }
  .form-group { display: flex; flex-direction: column; gap: 6px; }
  .form-group label {
    font-family: var(--font-sans); font-size: 9px; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--color-texto-suave);
  }
  .form-group input {
    background: var(--color-blanco); border: 0.5px solid var(--color-crema-oscuro);
    color: var(--color-texto); font-family: var(--font-sans);
    font-size: 13px; font-weight: 300; padding: 13px 16px;
    outline: none; transition: border-color 0.2s;
    -webkit-appearance: none; border-radius: 0;
  }
  .form-group input:focus { border-color: var(--color-azul-claro); background: var(--color-crema); }
  .btn-submit {
    font-family: var(--font-sans); font-size: 11px; font-weight: 500;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--color-blanco); background: var(--color-azul);
    border: none; padding: 15px 40px; cursor: pointer;
    transition: background 0.3s; width: 100%;
  }
  .btn-submit:hover { background: var(--color-azul-medio); }

  .login-msg { text-align: center; font-size: 13px; padding: 12px; font-family: var(--font-sans); }
  .login-msg.error { color: #b91c1c; background: #fef2f2; }
  .hidden { display: none !important; }
</style>

<script>
  import { createClient } from "@supabase/supabase-js";

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  );

  // If already logged in, redirect to panel
  const { data: { session } } = await supabase.auth.getSession();
  if (session) {
    document.cookie = "sb-access-token=" + session.access_token + "; path=/; max-age=3600; SameSite=Strict; Secure";
    window.location.href = "/admin/panel";
  }

  const loginForm = document.getElementById("login-form") as HTMLFormElement;
  const loginMessage = document.getElementById("login-message") as HTMLDivElement;

  loginForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const btn = document.getElementById("submitBtn") as HTMLButtonElement;
    btn.textContent = "Entrando…";

    const email = (document.getElementById("admin-email") as HTMLInputElement).value;
    const password = (document.getElementById("admin-password") as HTMLInputElement).value;

    const { data, error } = await supabase.auth.signInWithPassword({ email, password });

    if (error) {
      loginMessage.textContent = "Credenciales incorrectas.";
      loginMessage.className = "login-msg error";
      loginMessage.classList.remove("hidden");
      btn.textContent = "Iniciar sesión";
    } else if (data.session) {
      document.cookie = "sb-access-token=" + data.session.access_token + "; path=/; max-age=3600; SameSite=Strict; Secure";
      window.location.href = "/admin/panel";
    }
  });
</script>

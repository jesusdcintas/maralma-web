---
import AdminLayout from "../../../layouts/AdminLayout.astro";
---

<AdminLayout title="Carpetas · Admin · Maralma" section="carpetas">
  <h1 class="adm-page-title">Carpetas</h1>
  <p class="adm-page-subtitle">Gestiona las carpetas de Cloudinary para organizar las imágenes.</p>

  <!-- NEW FOLDER -->
  <div class="carp-toolbar">
    <button class="toolbar-btn" id="newFolderBtn">+ Nueva carpeta</button>
  </div>
  <div class="carp-new-form hidden" id="newFolderForm">
    <input type="text" id="newFolderInput" class="carp-input" placeholder="Nombre de la carpeta" />
    <button class="toolbar-btn" id="createFolderBtn">Crear</button>
    <button class="toolbar-btn" id="cancelFolderBtn">Cancelar</button>
  </div>

  <!-- FOLDERS LIST -->
  <div class="carp-list" id="folderList">
    <p class="carp-loading" id="foldersLoading">Cargando carpetas…</p>
  </div>
  <p class="carp-empty hidden" id="foldersEmpty">No hay carpetas creadas.</p>

  <!-- MODAL -->
  <div class="modal-overlay hidden" id="modalOverlay">
    <div class="modal-box">
      <p class="modal-text" id="modalText"></p>
      <div class="modal-actions" id="modalActions"></div>
    </div>
  </div>
</AdminLayout>

<style>
  .carp-toolbar { margin-bottom: 16px; }
  .toolbar-btn {
    font-family: var(--font-sans); font-size: 10px; font-weight: 500;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--color-texto-suave); background: transparent;
    border: 0.5px solid var(--color-crema-oscuro); padding: 8px 18px;
    cursor: pointer; transition: all 0.2s;
  }
  .toolbar-btn:hover { border-color: var(--color-azul); color: var(--color-azul); }
  .carp-new-form {
    display: flex; gap: 8px; align-items: center; margin-bottom: 24px;
  }
  .carp-input {
    font-family: var(--font-sans); font-size: 12px; padding: 8px 14px;
    border: 0.5px solid var(--color-crema-oscuro); background: var(--color-blanco);
    color: var(--color-texto); flex: 1; max-width: 300px;
    transition: border-color 0.2s; outline: none;
  }
  .carp-input:focus { border-color: var(--color-azul); }

  .carp-list { display: grid; gap: 8px; }
  .carp-loading, .carp-empty {
    text-align: center; font-size: 13px; color: var(--color-texto-suave); padding: 40px 0;
  }
  .carp-card {
    display: flex; align-items: center; gap: 16px;
    background: var(--color-blanco); border: 0.5px solid var(--color-crema-oscuro);
    padding: 16px 20px; transition: border-color 0.2s;
  }
  .carp-card:hover { border-color: var(--color-azul-claro); }
  .carp-icon { color: var(--color-azul); flex-shrink: 0; opacity: 0.6; }
  .carp-info { flex: 1; }
  .carp-name {
    font-size: 14px; font-weight: 400; color: var(--color-azul);
    margin-bottom: 2px;
  }
  .carp-path {
    font-size: 11px; color: var(--color-texto-suave); font-weight: 300;
    font-family: monospace;
  }
  .carp-delete {
    font-family: var(--font-sans); font-size: 9px; font-weight: 500;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: #b91c1c; background: transparent;
    border: 0.5px solid transparent; padding: 6px 14px;
    cursor: pointer; transition: all 0.2s; opacity: 0;
  }
  .carp-card:hover .carp-delete { opacity: 1; }
  .carp-delete:hover { border-color: #b91c1c; }

  .modal-overlay {
    position: fixed; inset: 0; z-index: 1000;
    background: rgba(15,26,32,0.55); backdrop-filter: blur(4px);
    display: flex; align-items: center; justify-content: center;
  }
  .modal-box {
    background: var(--color-blanco); max-width: 400px; width: 100%;
    padding: 40px 36px 32px; text-align: center;
    border: 0.5px solid var(--color-crema-oscuro);
  }
  .modal-text {
    font-family: var(--font-sans); font-size: 14px; font-weight: 300;
    color: var(--color-texto); line-height: 1.7; margin-bottom: 28px;
  }
  .modal-actions { display: flex; gap: 10px; justify-content: center; }
  .modal-btn {
    font-family: var(--font-sans); font-size: 10px; font-weight: 500;
    letter-spacing: 0.16em; text-transform: uppercase;
    padding: 12px 28px; cursor: pointer; transition: all 0.2s;
    border: 0.5px solid var(--color-crema-oscuro);
    background: transparent; color: var(--color-texto-suave);
  }
  .modal-btn:hover { border-color: var(--color-azul); color: var(--color-azul); }
  .modal-btn.danger {
    background: #7f1d1d; color: var(--color-blanco); border-color: #7f1d1d;
  }
  .modal-btn.danger:hover { background: #991b1b; }
  .hidden { display: none !important; }
</style>

<script>
  import { createClient } from "@supabase/supabase-js";

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  );

  let accessToken = "";

  const isSecure = window.location.protocol === "https:";
  const cookieFlags = "; path=/; max-age=3600; SameSite=Strict" + (isSecure ? "; Secure" : "");
  function getCookie(name: string): string | null {
    const match = document.cookie.match(new RegExp("(?:^|; )" + name + "=([^;]*)"));
    return match ? decodeURIComponent(match[1]) : null;
  }
  accessToken = getCookie("sb-access-token") || "";
  if (accessToken) {
    loadFolders();
  } else {
    window.location.href = "/admin";
  }

  const folderList = document.getElementById("folderList") as HTMLDivElement;
  const foldersLoading = document.getElementById("foldersLoading") as HTMLParagraphElement;
  const foldersEmpty = document.getElementById("foldersEmpty") as HTMLParagraphElement;

  async function loadFolders() {
    foldersLoading.classList.remove("hidden");
    foldersEmpty.classList.add("hidden");
    folderList.querySelectorAll(".carp-card").forEach((c) => c.remove());

    try {
      const res = await fetch("/api/admin/folders");
      if (!res.ok) throw new Error("Fetch failed");
      const folders: Array<{ id: string; name: string; slug: string; cloudinary_path: string; tipo: string }> = await res.json();
      foldersLoading.classList.add("hidden");

      if (!folders.length) {
        foldersEmpty.classList.remove("hidden");
        return;
      }

      for (const f of folders) {
        const card = document.createElement("div");
        card.className = "carp-card";
        card.innerHTML =
          '<div class="carp-icon">' +
            '<svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/></svg>' +
          '</div>' +
          '<div class="carp-info">' +
            '<p class="carp-name">' + escapeHtml(f.name) + '</p>' +
            '<p class="carp-path">' + escapeHtml(f.cloudinary_path) + '</p>' +
          '</div>' +
          '<button class="carp-delete" data-id="' + f.id + '" data-name="' + escapeHtml(f.name) + '">Eliminar</button>';
        folderList.appendChild(card);
      }
    } catch {
      foldersLoading.textContent = "Error al cargar carpetas.";
    }
  }

  // Delete folder
  folderList.addEventListener("click", async (e) => {
    const btn = (e.target as HTMLElement).closest(".carp-delete") as HTMLButtonElement | null;
    if (!btn) return;
    const name = btn.dataset.name || "esta carpeta";
    const confirmed = await showConfirm('¿Eliminar la carpeta "' + name + '"? Solo se puede eliminar si está vacía.');
    if (!confirmed) return;
    try {
      const res = await fetch("/api/admin/folders", {
        method: "DELETE",
        headers: { "Content-Type": "application/json", Authorization: "Bearer " + accessToken },
        body: JSON.stringify({ id: btn.dataset.id }),
      });
      if (!res.ok) {
        const data = await res.json();
        showAlert(data.error || "Error al eliminar");
        return;
      }
      loadFolders();
    } catch {
      showAlert("Error al eliminar carpeta");
    }
  });

  // New folder
  const newFolderBtn = document.getElementById("newFolderBtn") as HTMLButtonElement;
  const newFolderForm = document.getElementById("newFolderForm") as HTMLDivElement;
  const newFolderInput = document.getElementById("newFolderInput") as HTMLInputElement;
  const createFolderBtn = document.getElementById("createFolderBtn") as HTMLButtonElement;
  const cancelFolderBtn = document.getElementById("cancelFolderBtn") as HTMLButtonElement;

  newFolderBtn.addEventListener("click", () => {
    newFolderForm.classList.remove("hidden");
    newFolderInput.focus();
  });
  cancelFolderBtn.addEventListener("click", () => {
    newFolderForm.classList.add("hidden");
    newFolderInput.value = "";
  });
  createFolderBtn.addEventListener("click", async () => {
    const name = newFolderInput.value.trim();
    if (!name) return;
    createFolderBtn.textContent = "Creando…";
    try {
      const res = await fetch("/api/admin/folders", {
        method: "POST",
        headers: { "Content-Type": "application/json", Authorization: "Bearer " + accessToken },
        body: JSON.stringify({ name }),
      });
      if (!res.ok) {
        const data = await res.json();
        showAlert(data.error || "Error al crear carpeta");
        return;
      }
      newFolderInput.value = "";
      newFolderForm.classList.add("hidden");
      loadFolders();
    } catch {
      showAlert("Error al crear carpeta");
    } finally {
      createFolderBtn.textContent = "Crear";
    }
  });
  newFolderInput.addEventListener("keydown", (e) => {
    if (e.key === "Enter") createFolderBtn.click();
    if (e.key === "Escape") cancelFolderBtn.click();
  });

  // Modal helpers
  const modalOverlay = document.getElementById("modalOverlay") as HTMLDivElement;
  const modalText = document.getElementById("modalText") as HTMLParagraphElement;
  const modalActions = document.getElementById("modalActions") as HTMLDivElement;

  function showAlert(message: string): void {
    modalText.textContent = message;
    modalActions.innerHTML = "";
    const btn = document.createElement("button");
    btn.className = "modal-btn";
    btn.textContent = "Aceptar";
    btn.addEventListener("click", () => modalOverlay.classList.add("hidden"));
    modalActions.appendChild(btn);
    modalOverlay.classList.remove("hidden");
  }

  function showConfirm(message: string): Promise<boolean> {
    return new Promise((resolve) => {
      modalText.textContent = message;
      modalActions.innerHTML = "";
      const cancelBtn = document.createElement("button");
      cancelBtn.className = "modal-btn";
      cancelBtn.textContent = "Cancelar";
      cancelBtn.addEventListener("click", () => { modalOverlay.classList.add("hidden"); resolve(false); });
      const okBtn = document.createElement("button");
      okBtn.className = "modal-btn danger";
      okBtn.textContent = "Eliminar";
      okBtn.addEventListener("click", () => { modalOverlay.classList.add("hidden"); resolve(true); });
      modalActions.appendChild(cancelBtn);
      modalActions.appendChild(okBtn);
      modalOverlay.classList.remove("hidden");
    });
  }

  modalOverlay.addEventListener("click", (e) => {
    if (e.target === modalOverlay) modalOverlay.classList.add("hidden");
  });

  function escapeHtml(str: string): string {
    return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
  }
</script>

---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Panel · Maralma" section="panel">
  <h1 class="adm-page-title">Panel de control</h1>
  <p class="adm-page-subtitle">Resumen de tu sitio web.</p>

  <!-- SUMMARY CARDS -->
  <div class="dash-cards" id="dashCards">
    <div class="dash-card">
      <div class="dash-card-icon">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/></svg>
      </div>
      <div class="dash-card-body">
        <span class="dash-card-value" id="cardQuotes">–</span>
        <span class="dash-card-label">Solicitudes</span>
      </div>
      <span class="dash-card-detail" id="cardQuotesPending"></span>
    </div>

    <div class="dash-card">
      <div class="dash-card-icon">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
      </div>
      <div class="dash-card-body">
        <span class="dash-card-value" id="cardPhotos">–</span>
        <span class="dash-card-label">Fotos en galería</span>
      </div>
    </div>

    <div class="dash-card">
      <div class="dash-card-icon">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
      </div>
      <div class="dash-card-body">
        <span class="dash-card-value" id="cardEvents">–</span>
        <span class="dash-card-label">Eventos</span>
      </div>
      <span class="dash-card-detail" id="cardEventsDetail"></span>
    </div>

    <div class="dash-card">
      <div class="dash-card-icon">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
      </div>
      <div class="dash-card-body">
        <span class="dash-card-value" id="cardTestimonios">–</span>
        <span class="dash-card-label">Testimonios</span>
      </div>
      <span class="dash-card-detail" id="cardTestimoniosDetail"></span>
    </div>
  </div>

  <!-- QUICK LINKS -->
  <div class="dash-quick">
    <h2 class="adm-section-title">Accesos rápidos</h2>
    <div class="dash-quick-grid">
      <a href="/admin/galeria/imagenes" class="dash-qlink">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M12 16V4m0 0l-4 4m4-4l4 4"/><path d="M20 16v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2"/></svg>
        Subir imágenes
      </a>
      <a href="/admin/galeria/eventos" class="dash-qlink">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
        Nuevo evento
      </a>
      <a href="/admin/solicitudes" class="dash-qlink">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/></svg>
        Ver solicitudes
      </a>
      <a href="/?cms=true" target="_blank" class="dash-qlink">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        Editar web
      </a>
    </div>
  </div>
</AdminLayout>

<style>
  .dash-cards {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 16px; margin-bottom: 40px;
  }
  .dash-card {
    background: var(--color-blanco); border: 0.5px solid var(--color-crema-oscuro);
    padding: 24px; display: flex; gap: 16px; align-items: flex-start;
    position: relative;
  }
  .dash-card-icon {
    width: 44px; height: 44px; background: rgba(30,58,79,0.06);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; color: var(--color-azul);
  }
  .dash-card-body { display: flex; flex-direction: column; }
  .dash-card-value {
    font-family: var(--font-serif); font-size: 28px; font-weight: 300;
    color: var(--color-azul); line-height: 1.1;
  }
  .dash-card-label {
    font-size: 11px; color: var(--color-texto-suave); font-weight: 300;
    letter-spacing: 0.04em; margin-top: 4px;
  }
  .dash-card-detail {
    position: absolute; top: 12px; right: 14px;
    font-size: 10px; color: var(--color-texto-suave); font-weight: 300;
    letter-spacing: 0.04em;
  }

  .dash-quick-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 12px;
  }
  .dash-qlink {
    display: flex; align-items: center; gap: 10px;
    background: var(--color-blanco); border: 0.5px solid var(--color-crema-oscuro);
    padding: 16px 20px; text-decoration: none;
    font-size: 13px; font-weight: 400; color: var(--color-azul);
    transition: all 0.2s;
  }
  .dash-qlink:hover { border-color: var(--color-azul); background: rgba(30,58,79,0.03); }
  .dash-qlink svg { flex-shrink: 0; }

  @media (max-width: 768px) {
    .dash-cards { grid-template-columns: 1fr 1fr; }
    .dash-quick-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 480px) {
    .dash-cards { grid-template-columns: 1fr; }
  }
</style>

<script>
  import { createClient } from "@supabase/supabase-js";

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  );

  const { data: { session } } = await supabase.auth.getSession();
  if (!session) {
    window.location.href = "/admin";
  } else {
    const token = session.access_token;

    // Refresh cookie
    const isSecure = window.location.protocol === "https:";
    document.cookie = "sb-access-token=" + token + "; path=/; max-age=3600; SameSite=Strict" + (isSecure ? "; Secure" : "");

    // Load dashboard data
    try {
      const res = await fetch("/api/admin/quotes?count_only=true", {
        headers: { Authorization: "Bearer " + token },
      });
      if (res.ok) {
        const data = await res.json();
        (document.getElementById("cardQuotes") as HTMLElement).textContent = String(data.total);
        if (data.pendientes > 0) {
          (document.getElementById("cardQuotesPending") as HTMLElement).textContent = data.pendientes + " pendientes";
        }
      }
    } catch { /* ignore */ }

    try {
      const res = await fetch("/api/admin/events", {
        headers: { Authorization: "Bearer " + token },
      });
      if (res.ok) {
        const events: Array<any> = await res.json();
        (document.getElementById("cardEvents") as HTMLElement).textContent = String(events.length);
        const pub = events.filter((e: any) => e.publicado).length;
        const draft = events.length - pub;
        (document.getElementById("cardEventsDetail") as HTMLElement).textContent =
          pub + " pub · " + draft + " borr";
      }
    } catch { /* ignore */ }

    try {
      const res = await fetch("/api/admin/testimonios?count_only=true", {
        headers: { Authorization: "Bearer " + token },
      });
      if (res.ok) {
        const data = await res.json();
        (document.getElementById("cardTestimonios") as HTMLElement).textContent = String(data.total);
        if (data.pendientes > 0) {
          (document.getElementById("cardTestimoniosDetail") as HTMLElement).textContent = data.pendientes + " pendientes";
        }
      }
    } catch { /* ignore */ }

    // Photo count from gallery table
    try {
      const { count } = await supabase
        .from("gallery")
        .select("*", { count: "exact", head: true })
        .not("categoria", "in", '("cms","cms_img")');
      (document.getElementById("cardPhotos") as HTMLElement).textContent = String(count || 0);
    } catch { /* ignore */ }
  }
</script>

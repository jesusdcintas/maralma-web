---
import Layout from "../layouts/Layout.astro";
import { t as _t, type Lang } from "../utils/i18n";
import { loadCms, c as _c, imgStyle as _imgStyle } from "../utils/cms";

const lang = (Astro.currentLocale ?? "es") as Lang;
const t = (key: string) => _t(key, lang);
const localePath = (path: string) => lang === "en" ? `/en${path}` : path;
const cms = await loadCms();
const c = (key: string) => _c(cms, key, lang);
const img = (key: string) => _imgStyle(cms, key);
---

<Layout title={t("weddings.title") + " · Maralma"} darkNav={true}>

  <!-- ═══ PAGE HERO ═══ -->
  <section class="page-hero">
    <div class="page-hero-bg"></div>
    <div class="page-hero-overlay"></div>
    <div class="page-hero-content">
      <span class="page-eyebrow" data-cms="weddings.eyebrow">{c("weddings.eyebrow")}</span>
      <h1 class="page-title" data-cms="weddings.page.hero_title">{cms.text["weddings.page.hero_title"] || "Tu boda,"}<br/><em>{cms.text["weddings.page.hero_title"] ? "" : "tu historia."}</em></h1>
      <svg class="hero-wave" width="60" height="12" viewBox="0 0 60 12" fill="none">
        <path d="M3 9 C11 3, 19 3, 27 6 C35 9, 43 9, 51 3" stroke="#a8c4c8" stroke-width="1" stroke-linecap="round" fill="none" opacity="0.6"/>
      </svg>
      <p class="page-subtitle" data-cms="weddings.page.hero_subtitle">{c("weddings.page.hero_subtitle")}</p>
    </div>
  </section>

  <!-- ═══ BODA CÓCTEL ═══ -->
  <section class="detail-section" id="cocktail">
    <div class="detail-inner">
      <div class="detail-photo reveal">
        <div class="detail-photo-bg dp-cocktail" data-cms-img="weddings.cocktail.photo" style={img("weddings.cocktail.photo")}></div>
      </div>
      <div class="detail-text reveal reveal-1">
        <span class="detail-tag">{t("weddings.cocktail.tag")}</span>
{cms.text["weddings.cocktail.title"]
          ? <h2 class="detail-title" data-cms="weddings.cocktail.title">{cms.text["weddings.cocktail.title"]}</h2>
          : <h2 class="detail-title" data-cms="weddings.cocktail.title">{t("weddings.cocktail.title_1")}<br/><em>{t("weddings.cocktail.title_2")}</em></h2>
        }
        <div class="detail-border"></div>
        <p class="detail-desc" data-cms="weddings.cocktail.desc">{c("weddings.cocktail.desc")}</p>
        <ul class="detail-list">
          <li>{t("weddings.cocktail.items.0")}</li>
          <li>{t("weddings.cocktail.items.1")}</li>
          <li>{t("weddings.cocktail.items.2")}</li>
          <li>{t("weddings.cocktail.items.3")}</li>
          <li>{t("weddings.cocktail.items.4")}</li>
          <li>{t("weddings.cocktail.items.5")}</li>
        </ul>
        <a href={localePath("/contacto")} class="detail-cta">{t("events.cta")} →</a>
      </div>
    </div>
  </section>

  <!-- ═══ FRASE ═══ -->
  <div class="frase dark">
{cms.text["weddings.page.phrase"]
      ? <p class="frase-text" data-cms="weddings.page.phrase">{cms.text["weddings.page.phrase"]}</p>
      : <p class="frase-text" data-cms="weddings.page.phrase"><em>"{t("weddings.page.phrase")}"</em></p>
    }
  </div>

  <!-- ═══ BODA BANQUETE ═══ -->
  <section class="detail-section detail-alt" id="banquete">
    <div class="detail-inner detail-reverse">
      <div class="detail-text reveal">
        <span class="detail-tag">{t("weddings.banquet.tag")}</span>
{cms.text["weddings.banquet.title"]
          ? <h2 class="detail-title" data-cms="weddings.banquet.title">{cms.text["weddings.banquet.title"]}</h2>
          : <h2 class="detail-title" data-cms="weddings.banquet.title">{t("weddings.banquet.title_1")}<br/><em>{t("weddings.banquet.title_2")}</em></h2>
        }
        <div class="detail-border"></div>
        <p class="detail-desc" data-cms="weddings.banquet.desc">{c("weddings.banquet.desc")}</p>
        <ul class="detail-list">
          <li>{t("weddings.banquet.items.0")}</li>
          <li>{t("weddings.banquet.items.1")}</li>
          <li>{t("weddings.banquet.items.2")}</li>
          <li>{t("weddings.banquet.items.3")}</li>
          <li>{t("weddings.banquet.items.4")}</li>
          <li>{t("weddings.banquet.items.5")}</li>
        </ul>
        <a href={localePath("/contacto")} class="detail-cta">{t("events.cta")} →</a>
      </div>
      <div class="detail-photo reveal reveal-1">
        <div class="detail-photo-bg dp-banquet" data-cms-img="weddings.banquet.photo" style={img("weddings.banquet.photo")}></div>
      </div>
    </div>
  </section>

  <!-- ═══ POR QUÉ MARALMA PARA TU BODA ═══ -->
  <section class="porque-boda">
    <div class="section-header reveal">
      <h2 class="section-title" data-cms="weddings.page.why_title">{c("weddings.page.why_title")}</h2>
      <span class="section-eyebrow">{t("why.eyebrow")}</span>
    </div>
    <div class="pq-grid">
      <div class="pq-card reveal">
        <div class="pq-number">01</div>
        <h3 class="pq-title" data-cms="weddings.page.why.0.title">{c("weddings.page.why.0.title")}</h3>
        <p class="pq-desc" data-cms="weddings.page.why.0.desc">{c("weddings.page.why.0.desc")}</p>
      </div>
      <div class="pq-card reveal reveal-1">
        <div class="pq-number">02</div>
        <h3 class="pq-title" data-cms="weddings.page.why.1.title">{c("weddings.page.why.1.title")}</h3>
        <p class="pq-desc" data-cms="weddings.page.why.1.desc">{c("weddings.page.why.1.desc")}</p>
      </div>
      <div class="pq-card reveal reveal-2">
        <div class="pq-number">03</div>
        <h3 class="pq-title" data-cms="weddings.page.why.2.title">{c("weddings.page.why.2.title")}</h3>
        <p class="pq-desc" data-cms="weddings.page.why.2.desc">{c("weddings.page.why.2.desc")}</p>
      </div>
    </div>
  </section>

  <!-- ═══ CTA FINAL ═══ -->
  <section class="cta-final">
    <p class="cta-eyebrow reveal" data-cms="cta.eyebrow">{c("cta.eyebrow")}</p>
    <h2 class="cta-title reveal" data-cms="weddings.page.cta_title">{c("weddings.page.cta_title")}</h2>
    <p class="cta-sub reveal" data-cms="weddings.page.cta_body">{c("weddings.page.cta_body")}</p>
    <div class="cta-btns reveal">
      <a href={localePath("/contacto")} class="cta-btn cta-btn-form">
        <svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        {t("cta.form")}
      </a>
      <a href="https://wa.me/34658403496" class="cta-btn cta-btn-wa" target="_blank" rel="noopener noreferrer">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/></svg>
        {t("cta.whatsapp")}
      </a>
      <a href="tel:+34658403496" class="cta-btn cta-btn-call">
        <svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.5 2 2 0 0 1 3.6 1.32h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6.13 6.13l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        {t("cta.call")}
      </a>
    </div>
  </section>

</Layout>

<style>
/* ═══ PAGE HERO ═══ */
.page-hero {
  position: relative; min-height: 70vh;
  display: flex; align-items: center;
  overflow: hidden; background: var(--color-negro);
}
.page-hero-bg {
  position: absolute; inset: 0;
  background: linear-gradient(160deg, #0a1820 0%, #1e3a4f 45%, #2d5169 100%);
}
.page-hero-overlay {
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 60% 80% at 80% 50%, rgba(168,196,200,0.07) 0%, transparent 60%);
}
.page-hero-content {
  position: relative; z-index: 2;
  padding: 160px 60px 80px; max-width: 680px;
}
.page-eyebrow {
  font-size: 10px; letter-spacing: 0.24em; text-transform: uppercase;
  color: var(--color-azul-claro); margin-bottom: 24px; display: block;
  animation: fadeUp 1s ease 0.3s both;
}
.page-title {
  font-family: var(--font-serif);
  font-size: clamp(48px, 7vw, 90px);
  font-weight: 300; color: var(--color-blanco);
  line-height: 0.92; letter-spacing: -0.01em; margin-bottom: 0;
  animation: fadeUp 1s ease 0.5s both;
}
.page-title em { font-style: italic; color: var(--color-azul-claro); }
.hero-wave {
  display: block; margin: 22px 0 24px;
  animation: fadeUp 1s ease 0.7s both;
}
.page-subtitle {
  font-family: var(--font-serif); font-style: italic;
  font-size: clamp(15px, 2vw, 19px); font-weight: 300;
  color: rgba(253,252,250,0.5); line-height: 1.7;
  animation: fadeUp 1s ease 0.9s both;
}


/* ═══ DETAIL SECTIONS ═══ */
.detail-section { background: var(--color-blanco); padding: 0; }
.detail-alt { background: var(--color-crema); }
.detail-inner {
  display: grid; grid-template-columns: 1fr 1fr; min-height: 600px;
}
.detail-reverse { direction: rtl; }
.detail-reverse > * { direction: ltr; }
.detail-photo {
  position: relative; overflow: hidden; min-height: 400px;
}
.detail-photo-bg {
  position: absolute; inset: 0;
  transition: transform 0.7s ease;
}
.detail-photo:hover .detail-photo-bg { transform: scale(1.04); }
.dp-cocktail { background: linear-gradient(160deg, #1a3347 0%, #2d5169 100%); }
.dp-banquet { background: linear-gradient(160deg, #152a38 0%, #1e3a4f 100%); }
.detail-text {
  padding: 80px 70px;
  display: flex; flex-direction: column; justify-content: center;
}
.detail-tag {
  font-size: 9px; letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--color-azul-claro); margin-bottom: 14px; display: block;
}
.detail-title {
  font-family: var(--font-serif);
  font-size: clamp(30px, 3.5vw, 48px);
  font-weight: 300; color: var(--color-azul);
  line-height: 1.05; text-transform: uppercase;
  letter-spacing: 0.04em; margin-bottom: 0;
}
.detail-title em {
  font-style: italic; color: var(--color-azul);
  display: block;
}
.detail-border {
  width: 36px; height: 2px;
  background: var(--color-azul-claro);
  margin: 20px 0;
}
.detail-desc {
  font-size: 15px; font-weight: 300; color: var(--color-texto-suave);
  line-height: 1.9; margin-bottom: 24px;
}
.detail-list {
  list-style: none; padding: 0; margin-bottom: 36px;
  display: flex; flex-direction: column; gap: 10px;
}
.detail-list li {
  font-size: 13px; font-weight: 300; color: var(--color-texto-suave);
  padding-left: 18px; position: relative; line-height: 1.6;
}
.detail-list li::before {
  content: ''; position: absolute; left: 0; top: 7px;
  width: 5px; height: 5px; border-radius: 50%;
  background: var(--color-azul-claro);
}
.detail-cta {
  display: inline-block; font-family: var(--font-sans);
  font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase;
  color: var(--color-azul); text-decoration: none;
  border-bottom: 0.5px solid var(--color-azul); padding-bottom: 3px;
  transition: opacity 0.2s; align-self: flex-start;
}
.detail-cta:hover { opacity: 0.6; }

/* ═══ FRASE ═══ */
.frase { padding: 80px 60px; text-align: center; background: var(--color-blanco); }
.frase-text {
  font-family: var(--font-serif);
  font-size: clamp(26px, 4vw, 52px);
  font-weight: 300; font-style: italic;
  color: var(--color-azul); line-height: 1.3;
  max-width: 800px; margin: 0 auto;
}
.frase.dark { background: var(--color-azul); }
.frase.dark .frase-text { color: var(--color-blanco); }
.frase.dark .frase-text em { color: var(--color-azul-claro); }

/* ═══ SECTION HEADER ═══ */
.section-header {
  display: flex; align-items: baseline; justify-content: space-between;
  margin-bottom: 56px; border-bottom: 0.5px solid var(--color-crema-oscuro);
  padding-bottom: 22px;
}
.section-title {
  font-family: var(--font-serif);
  font-size: clamp(30px, 4vw, 50px);
  font-weight: 300; color: var(--color-azul);
}
.section-eyebrow {
  font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase;
  color: var(--color-texto-suave);
}

/* ═══ POR QUÉ MARALMA ═══ */
.porque-boda { background: var(--color-blanco); padding: 100px 60px; }
.pq-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 2px; }
.pq-card {
  padding: 40px 32px;
  border: 0.5px solid var(--color-crema-oscuro);
  transition: border-color 0.3s, background 0.3s;
}
.pq-card:hover { border-color: var(--color-azul-claro); background: var(--color-crema); }
.pq-number {
  font-family: var(--font-serif); font-size: 56px; font-weight: 300;
  color: var(--color-crema-oscuro); line-height: 1; margin-bottom: 16px;
  transition: color 0.3s;
}
.pq-card:hover .pq-number { color: var(--color-azul-claro); }
.pq-title {
  font-family: var(--font-serif); font-size: 20px; font-weight: 400;
  color: var(--color-azul); margin-bottom: 10px;
}
.pq-desc { font-size: 13px; font-weight: 300; color: var(--color-texto-suave); line-height: 1.8; }

/* ═══ CTA FINAL ═══ */
.cta-final { background: var(--color-azul); padding: 100px 60px; text-align: center; }
.cta-eyebrow {
  font-size: 10px; letter-spacing: 0.24em; text-transform: uppercase;
  color: var(--color-azul-claro); margin-bottom: 20px;
}
.cta-title {
  font-family: var(--font-serif);
  font-size: clamp(36px, 5vw, 64px);
  font-weight: 300; color: var(--color-blanco);
  line-height: 1.1; margin-bottom: 16px;
}
.cta-sub {
  font-size: 14px; font-weight: 300; color: rgba(253,252,250,0.5);
  max-width: 440px; margin: 0 auto 52px; line-height: 1.9;
}
.cta-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
.cta-btn {
  display: flex; align-items: center; gap: 10px;
  font-family: var(--font-sans);
  font-size: 11px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase;
  padding: 14px 26px; text-decoration: none; transition: all 0.3s;
  border: 0.5px solid;
}
.cta-btn svg { width: 16px; height: 16px; flex-shrink: 0; }
.cta-btn-form { color: var(--color-azul); background: var(--color-blanco); border-color: var(--color-blanco); }
.cta-btn-form:hover { background: var(--color-crema); }
.cta-btn-wa { color: #25d366; border-color: rgba(37,211,102,0.3); }
.cta-btn-wa:hover { background: rgba(37,211,102,0.1); border-color: #25d366; }
.cta-btn-call { color: var(--color-azul-claro); border-color: rgba(168,196,200,0.3); }
.cta-btn-call:hover { background: rgba(168,196,200,0.1); border-color: var(--color-azul-claro); }

/* ═══ REVEAL ═══ */
.reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.8s ease, transform 0.8s ease; }
.reveal.visible { opacity: 1; transform: none; }
.reveal-1 { transition-delay: 0.1s; }
.reveal-2 { transition-delay: 0.2s; }

/* ═══ RESPONSIVE ═══ */
@media (max-width: 768px) {
  .page-hero-content { padding: 120px 24px 60px; }
  .detail-inner { grid-template-columns: 1fr; }
  .detail-reverse { direction: ltr; }
  .detail-text { padding: 48px 24px; }
  .detail-photo { min-height: 280px; }
  .porque-boda { padding: 60px 24px; }
  .pq-grid { grid-template-columns: 1fr; }
  .cta-final { padding: 60px 24px; }
  .cta-btns { flex-direction: column; align-items: center; }
  .frase { padding: 48px 24px; }
  .section-header { flex-direction: column; gap: 8px; }
}
</style>

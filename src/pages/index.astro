---
import Layout from "../layouts/Layout.astro";
import { t as _t, type Lang } from "../utils/i18n";
import { loadCms, c as _c, imgStyle as _imgStyle } from "../utils/cms";

const lang = (Astro.currentLocale ?? "es") as Lang;
const t = (key: string) => _t(key, lang);
const localePath = (path: string) => lang === "en" ? `/en${path}` : path;
const cms = await loadCms();
const c = (key: string) => _c(cms, key, lang);
const img = (key: string) => _imgStyle(cms, key);
---

<Layout darkNav={true}>

  <!-- ═══ HERO VIDEO ═══ -->
  <section class="hero">
    <div class="hero-video-fallback"></div>
    <video class="hero-video" id="heroVideo" autoplay muted loop playsinline>
      <source src="/video/hero.mp4" type="video/mp4" />
    </video>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <p class="hero-eyebrow" data-cms="hero.eyebrow">{c("hero.eyebrow")}</p>
      <img src="/img/logo-blanco.png" alt="MarAlma" class="hero-logo-img" />
      <p class="hero-tagline" data-cms="hero.tagline">{c("hero.tagline")}</p>
      <div class="hero-btns">
        <a href={localePath("/contacto")} class="btn-primary">{t("hero.cta_primary")}</a>
        <a href="#servicios" class="btn-ghost">{t("hero.cta_secondary")}</a>
      </div>
    </div>
    <button class="hero-mute" id="muteBtn">{t("hero.mute_pause")}</button>
  </section>

  <!-- ═══ CLAIM GRANDE ═══ -->
  <section class="claim-full">
{cms.text["claim.full"]
      ? <p class="claim-full-text" data-cms="claim.full">{cms.text["claim.full"]}</p>
      : <p class="claim-full-text" data-cms="claim.full">
          {t("claim.text_1")} <em>{t("claim.text_em_1")}</em><br/>
          {t("claim.text_2")} <em>{t("claim.text_em_2")}</em>
        </p>
    }
    <p class="claim-sub" data-cms="claim.subtitle">{c("claim.subtitle")}</p>
  </section>

  <!-- ═══ SERVICIOS ═══ -->
  <section class="servicios" id="servicios">
    <div class="section-header reveal">
      <h2 class="section-title" data-cms="services.title">{c("services.title")}</h2>
      <span class="section-eyebrow" data-cms="services.eyebrow">{c("services.eyebrow")}</span>
    </div>
    <div class="servicios-grid">
      <div class="srv-card reveal">
        <div class="srv-photo"><div class="srv-photo-bg sp-bodas" data-cms-img="services.weddings.photo" style={img("services.weddings.photo")}></div></div>
        <div class="srv-body">
          <p class="srv-label">{t("services.label")}</p>
          <h3 class="srv-title" data-cms="services.weddings.title">{c("services.weddings.title")}</h3>
          <p class="srv-desc" data-cms="services.weddings.desc">{c("services.weddings.desc")}</p>
          <a href={localePath("/bodas")} class="srv-link">{t("services.weddings.link")} →</a>
        </div>
      </div>
      <div class="srv-card reveal reveal-1">
        <div class="srv-photo"><div class="srv-photo-bg sp-corp" data-cms-img="services.corporate.photo" style={img("services.corporate.photo")}></div></div>
        <div class="srv-body">
          <p class="srv-label">{t("services.label")}</p>
          <h3 class="srv-title" data-cms="services.corporate.title">{c("services.corporate.title")}</h3>
          <p class="srv-desc" data-cms="services.corporate.desc">{c("services.corporate.desc")}</p>
          <a href={localePath("/eventos")} class="srv-link">{t("services.corporate.link")} →</a>
        </div>
      </div>
      <div class="srv-card reveal reveal-2">
        <div class="srv-photo"><div class="srv-photo-bg sp-priv" data-cms-img="services.private.photo" style={img("services.private.photo")}></div></div>
        <div class="srv-body">
          <p class="srv-label">{t("services.label")}</p>
          <h3 class="srv-title" data-cms="services.private.title">{c("services.private.title")}</h3>
          <p class="srv-desc" data-cms="services.private.desc">{c("services.private.desc")}</p>
          <a href={localePath("/eventos")} class="srv-link">{t("services.private.link")} →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FRASE 1 (dark) ═══ -->
  <div class="frase dark">
{cms.text["phrases.p1"]
      ? <p class="frase-text" data-cms="phrases.p1">{cms.text["phrases.p1"]}</p>
      : <p class="frase-text" data-cms="phrases.p1"><em>{t("phrases.p1_1")}</em><br/>{t("phrases.p1_2")} <strong>{t("phrases.p1_strong")}</strong></p>
    }
  </div>

  <!-- ═══ BODAS SPLIT ═══ -->
  <section class="bodas-wrap" id="bodas">
    <div class="bodas-header">
      <div class="section-header reveal" style="border:none;margin:0;padding:0">
        <h2 class="section-title" style="color:var(--color-blanco)">{t("weddings.title")}</h2>
        <span class="section-eyebrow">{t("weddings.eyebrow")}</span>
      </div>
    </div>
    <div class="bodas-split">
      <div class="boda-card reveal">
        <div class="boda-photo"><div class="boda-photo-bg bp-coctel" data-cms-img="weddings.cocktail.photo" style={img("weddings.cocktail.photo")}></div></div>
        <div class="boda-body">
          <span class="boda-tag">{t("weddings.cocktail.tag")}</span>
          <h3 class="boda-title">{t("weddings.cocktail.title_1")}<br/>{t("weddings.cocktail.title_2")}</h3>
          <p class="boda-sub">{t("weddings.cocktail.subtitle")}</p>
          <a href={localePath("/bodas")} class="boda-cta">{t("weddings.cocktail.cta")}</a>
        </div>
      </div>
      <div class="boda-card reveal reveal-1">
        <div class="boda-photo"><div class="boda-photo-bg bp-banquete" data-cms-img="weddings.banquet.photo" style={img("weddings.banquet.photo")}></div></div>
        <div class="boda-body">
          <span class="boda-tag">{t("weddings.banquet.tag")}</span>
          <h3 class="boda-title">{t("weddings.banquet.title_1")}<br/>{t("weddings.banquet.title_2")}</h3>
          <p class="boda-sub">{t("weddings.banquet.subtitle")}</p>
          <a href={localePath("/bodas")} class="boda-cta">{t("weddings.banquet.cta")}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FRASE 2 (crema) ═══ -->
  <div class="frase crema">
{cms.text["phrases.p2"]
      ? <p class="frase-text" data-cms="phrases.p2">{cms.text["phrases.p2"]}</p>
      : <p class="frase-text" data-cms="phrases.p2">{t("phrases.p2_1")}<br/><em>{t("phrases.p2_2")}</em></p>
    }
  </div>

  <!-- ═══ POR QUÉ MARALMA ═══ -->
  <section class="porque">
    <div class="section-header reveal">
      <h2 class="section-title">{t("why.title")}</h2>
      <span class="section-eyebrow">{t("why.eyebrow")}</span>
    </div>
    <div class="porque-grid">
      <div class="pq-card reveal">
        <div class="pq-number">01</div>
        <h3 class="pq-title" data-cms="why.items.0.title">{c("why.items.0.title")}</h3>
        <p class="pq-desc" data-cms="why.items.0.desc">{c("why.items.0.desc")}</p>
      </div>
      <div class="pq-card reveal reveal-1">
        <div class="pq-number">02</div>
        <h3 class="pq-title" data-cms="why.items.1.title">{c("why.items.1.title")}</h3>
        <p class="pq-desc" data-cms="why.items.1.desc">{c("why.items.1.desc")}</p>
      </div>
      <div class="pq-card reveal reveal-2">
        <div class="pq-number">03</div>
        <h3 class="pq-title" data-cms="why.items.2.title">{c("why.items.2.title")}</h3>
        <p class="pq-desc" data-cms="why.items.2.desc">{c("why.items.2.desc")}</p>
      </div>
      <div class="pq-card reveal reveal-3">
        <div class="pq-number">04</div>
        <h3 class="pq-title" data-cms="why.items.3.title">{c("why.items.3.title")}</h3>
        <p class="pq-desc" data-cms="why.items.3.desc">{c("why.items.3.desc")}</p>
      </div>
    </div>
  </section>

  <!-- ═══ RESEÑAS (slider) ═══ -->
  <section class="resenas">
    <div class="resenas-header reveal">
      <div>
        <h2 class="section-title">{t("reviews.title")}</h2>
        <p class="resenas-sub">{t("reviews.eyebrow")}</p>
      </div>
      <div class="resenas-nav">
        <button class="resena-nav-btn" id="prevSlide">←</button>
        <button class="resena-nav-btn" id="nextSlide">→</button>
      </div>
    </div>
    <div class="resenas-track-wrap">
      <div class="resenas-track" id="resenasTrack">
        <div class="resena-card featured">
          <div class="resena-stars"><div class="star"></div><div class="star"></div><div class="star"></div><div class="star"></div><div class="star"></div></div>
          <span class="resena-mark">"</span>
          <p class="resena-text" data-cms="reviews.items.0.text">{c("reviews.items.0.text")}</p>
          <div class="resena-divider"></div>
          <p class="resena-name" data-cms="reviews.items.0.name">{c("reviews.items.0.name")}</p>
          <p class="resena-event" data-cms="reviews.items.0.event">{c("reviews.items.0.event")}</p>
        </div>
        <div class="resena-card">
          <div class="resena-stars"><div class="star"></div><div class="star"></div><div class="star"></div><div class="star"></div><div class="star"></div></div>
          <span class="resena-mark">"</span>
          <p class="resena-text" data-cms="reviews.items.1.text">{c("reviews.items.1.text")}</p>
          <div class="resena-divider"></div>
          <p class="resena-name" data-cms="reviews.items.1.name">{c("reviews.items.1.name")}</p>
          <p class="resena-event" data-cms="reviews.items.1.event">{c("reviews.items.1.event")}</p>
        </div>
        <div class="resena-card">
          <div class="resena-stars"><div class="star"></div><div class="star"></div><div class="star"></div><div class="star"></div><div class="star"></div></div>
          <span class="resena-mark">"</span>
          <p class="resena-text" data-cms="reviews.items.2.text">{c("reviews.items.2.text")}</p>
          <div class="resena-divider"></div>
          <p class="resena-name" data-cms="reviews.items.2.name">{c("reviews.items.2.name")}</p>
          <p class="resena-event" data-cms="reviews.items.2.event">{c("reviews.items.2.event")}</p>
        </div>
        <div class="resena-card">
          <div class="resena-stars"><div class="star"></div><div class="star"></div><div class="star"></div><div class="star"></div><div class="star"></div></div>
          <span class="resena-mark">"</span>
          <p class="resena-text" data-cms="reviews.items.3.text">{c("reviews.items.3.text")}</p>
          <div class="resena-divider"></div>
          <p class="resena-name" data-cms="reviews.items.3.name">{c("reviews.items.3.name")}</p>
          <p class="resena-event" data-cms="reviews.items.3.event">{c("reviews.items.3.event")}</p>
        </div>
        <div class="resena-card">
          <div class="resena-stars"><div class="star"></div><div class="star"></div><div class="star"></div><div class="star"></div><div class="star"></div></div>
          <span class="resena-mark">"</span>
          <p class="resena-text" data-cms="reviews.items.4.text">{c("reviews.items.4.text")}</p>
          <div class="resena-divider"></div>
          <p class="resena-name" data-cms="reviews.items.4.name">{c("reviews.items.4.name")}</p>
          <p class="resena-event" data-cms="reviews.items.4.event">{c("reviews.items.4.event")}</p>
        </div>
      </div>
    </div>
    <div class="resenas-dots" id="resenasDots">
      <div class="resena-dot active"></div>
      <div class="resena-dot"></div>
      <div class="resena-dot"></div>
    </div>
  </section>

  <!-- ═══ FRASE 3 (blanco) ═══ -->
  <div class="frase">
{cms.text["phrases.p3"]
      ? <p class="frase-text" data-cms="phrases.p3">{cms.text["phrases.p3"]}</p>
      : <p class="frase-text" data-cms="phrases.p3"><em>"{t("phrases.p3_1")}<br/>{t("phrases.p3_2")}"</em></p>
    }
  </div>

  <!-- ═══ QUIÉNES SOMOS ═══ -->
  <section class="equipo" id="nosotros">
    <div class="section-header reveal">
      <h2 class="section-title">{t("team.title")}</h2>
      <span class="section-eyebrow">{t("team.eyebrow")}</span>
    </div>
    <div class="equipo-grid">
      <div class="equipo-card reveal">
        <div class="equipo-photo">
          <div class="ep-bg ep-juan" data-cms-img="team.juan.photo" style={img("team.juan.photo")}></div>
          <div class="ep-initial">J</div>
        </div>
        <div class="equipo-info">
          <p class="equipo-rol" data-cms="team.juan.role">{c("team.juan.role")}</p>
          <h3 class="equipo-nombre" data-cms="team.juan.name">{c("team.juan.name")}</h3>
          <p class="equipo-frase" data-cms="team.juan.quote">"{c("team.juan.quote")}"</p>
          <p class="equipo-bio" data-cms="team.juan.bio">{c("team.juan.bio")}</p>
        </div>
      </div>
      <div class="equipo-card reveal reveal-1">
        <div class="equipo-photo">
          <div class="ep-bg ep-miriam" data-cms-img="team.miriam.photo" style={img("team.miriam.photo")}></div>
          <div class="ep-initial">M</div>
        </div>
        <div class="equipo-info">
          <p class="equipo-rol" data-cms="team.miriam.role">{c("team.miriam.role")}</p>
          <h3 class="equipo-nombre" data-cms="team.miriam.name">{c("team.miriam.name")}</h3>
          <p class="equipo-frase" data-cms="team.miriam.quote">"{c("team.miriam.quote")}"</p>
          <p class="equipo-bio" data-cms="team.miriam.bio">{c("team.miriam.bio")}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ GALERÍA ═══ -->
  <section class="galeria" id="galeria">
    <div class="galeria-header reveal">
      <h2 class="galeria-title">{t("gallery.title")}</h2>
      <div class="galeria-filters">
        <button class="gal-filter active" data-cat="all">{t("gallery.filters.all")}</button>
        <button class="gal-filter" data-cat="bodas">{t("gallery.filters.weddings")}</button>
        <button class="gal-filter" data-cat="platos">{t("gallery.filters.dishes")}</button>
        <button class="gal-filter" data-cat="eventos">{t("gallery.filters.events")}</button>
      </div>
    </div>
    <div class="galeria-grid">
      <div class="gal-item" data-cat="bodas">
        <div class="gi-bg-img gi-c1"></div>
        <div class="gi-hover"><div class="gi-icon"><svg width="16" height="16" fill="none" stroke="white" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg></div></div>
        <span class="gi-caption">{t("gallery.captions.0")}</span>
      </div>
      <div class="gal-item" data-cat="platos">
        <div class="gi-bg-img gi-c2"></div>
        <div class="gi-hover"><div class="gi-icon"><svg width="16" height="16" fill="none" stroke="white" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg></div></div>
        <span class="gi-caption">{t("gallery.captions.1")}</span>
      </div>
      <div class="gal-item" data-cat="platos">
        <div class="gi-bg-img gi-c3"></div>
        <div class="gi-hover"><div class="gi-icon"><svg width="16" height="16" fill="none" stroke="white" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg></div></div>
        <span class="gi-caption">{t("gallery.captions.2")}</span>
      </div>
      <div class="gal-item" data-cat="eventos">
        <div class="gi-bg-img gi-c4"></div>
        <div class="gi-hover"><div class="gi-icon"><svg width="16" height="16" fill="none" stroke="white" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg></div></div>
        <span class="gi-caption">{t("gallery.captions.3")}</span>
      </div>
      <div class="gal-item" data-cat="bodas">
        <div class="gi-bg-img gi-c5"></div>
        <div class="gi-hover"><div class="gi-icon"><svg width="16" height="16" fill="none" stroke="white" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg></div></div>
        <span class="gi-caption">{t("gallery.captions.4")}</span>
      </div>
      <div class="gal-item" data-cat="eventos">
        <div class="gi-bg-img gi-c6"></div>
        <div class="gi-hover"><div class="gi-icon"><svg width="16" height="16" fill="none" stroke="white" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg></div></div>
        <span class="gi-caption">{t("gallery.captions.5")}</span>
      </div>
    </div>
    <div class="galeria-cta">
      <p class="galeria-cta-text">{t("gallery.cta_phrase")}</p>
      <a href={localePath("/galeria")} class="galeria-ver">{t("gallery.cta")} →</a>
    </div>
  </section>

  <!-- ═══ CTA FINAL ═══ -->
  <section class="cta-final">
    <p class="cta-eyebrow reveal" data-cms="cta.eyebrow">{c("cta.eyebrow")}</p>
    <h2 class="cta-title reveal" data-cms="cta.title">{c("cta.title")}</h2>
    <p class="cta-sub reveal" data-cms="cta.desc">{c("cta.desc")}</p>
    <div class="cta-btns reveal">
      <a href={localePath("/contacto")} class="cta-btn cta-btn-form">
        <svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        {t("cta.form")}
      </a>
      <a href="https://wa.me/34XXXXXXXXX" class="cta-btn cta-btn-wa" target="_blank" rel="noopener noreferrer">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/></svg>
        {t("cta.whatsapp")}
      </a>
      <a href="tel:+34XXXXXXXXX" class="cta-btn cta-btn-call">
        <svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.5 2 2 0 0 1 3.6 1.32h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6.13 6.13l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        {t("cta.call")}
      </a>
      <a href="https://instagram.com/maralma.catering" class="cta-btn cta-btn-ig" target="_blank" rel="noopener noreferrer">
        <svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/></svg>
        Instagram
      </a>
    </div>
  </section>

</Layout>

<style>
/* ═══ HERO VIDEO ═══ */
.hero {
  position: relative; height: 100vh; min-height: 700px;
  display: flex; align-items: center; justify-content: center;
  overflow: hidden; background: var(--color-negro);
}
.hero-video {
  position: absolute; inset: 0; width: 100%; height: 100%;
  object-fit: cover; opacity: 0.55;
}
.hero-video-fallback {
  position: absolute; inset: 0;
  background: linear-gradient(160deg, #0a1820 0%, #1e3a4f 45%, #2d5169 100%);
}
.hero-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(0deg, rgba(10,24,32,0.7) 0%, rgba(10,24,32,0.1) 60%, rgba(10,24,32,0.3) 100%);
}
.hero-content {
  position: relative; z-index: 2;
  text-align: center; padding: 0 40px;
}
.hero-eyebrow {
  font-size: 10px; letter-spacing: 0.28em; text-transform: uppercase;
  color: var(--color-azul-claro); margin-bottom: 28px;
  animation: fadeUp 1s ease 0.4s both;
}
.hero-logo-img {
  display: block; margin: 0 auto 32px;
  width: clamp(180px, 30vw, 340px); height: auto;
  animation: fadeUp 1s ease 0.6s both;
}
.hero-tagline {
  font-family: var(--font-serif); font-style: italic;
  font-size: clamp(15px, 2vw, 20px); font-weight: 300;
  color: rgba(253,252,250,0.6); margin-bottom: 50px;
  animation: fadeUp 1s ease 1s both;
}
.hero-btns {

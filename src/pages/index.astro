</style>

<script>
  // Slider reseñas
  let slideIndex = 0;
  const track = document.getElementById("resenasTrack");
  const dots = document.querySelectorAll(".resena-dot");
  const prevBtn = document.getElementById("prevSlide");
  const nextBtn = document.getElementById("nextSlide");

  function updateSlider() {
    if (!track) return;
    const cards = track.querySelectorAll<HTMLElement>(".resena-card");
    if (!cards.length) return;
    const w = cards[0].offsetWidth + 20;
    track.style.transform = `translateX(-${slideIndex * w}px)`;
    dots.forEach((d, i) => d.classList.toggle("active", i === slideIndex));
  }

  function moveSlider(dir: number) {
    const cards = track?.querySelectorAll(".resena-card");
    if (!cards) return;
    const max = Math.ceil(cards.length / 3) - 1;
    slideIndex = Math.max(0, Math.min(slideIndex + dir, max));
    updateSlider();
  }

  prevBtn?.addEventListener("click", () => moveSlider(-1));
  nextBtn?.addEventListener("click", () => moveSlider(1));
  dots.forEach((dot, i) => dot.addEventListener("click", () => { slideIndex = i; updateSlider(); }));

  // Gallery filter
  document.querySelectorAll(".gal-filter").forEach(btn => {
    btn.addEventListener("click", () => {
      const cat = (btn as HTMLElement).dataset.cat;
      document.querySelectorAll(".gal-filter").forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
      document.querySelectorAll(".gal-item").forEach(item => {
        const el = item as HTMLElement;
        el.style.opacity = (cat === "all" || el.dataset.cat === cat) ? "1" : "0.2";
        el.style.transition = "opacity 0.4s";
      });
    });
  });

  // Hero mute toggle
  const muteBtn = document.getElementById("muteBtn");
  const heroVideo = document.querySelector(".hero-video") as HTMLVideoElement | null;
  let paused = false;
  muteBtn?.addEventListener("click", () => {
    if (!heroVideo) return;
    paused = !paused;
    if (paused) { heroVideo.pause(); } else { heroVideo.play(); }
  });

  // Load hero video from Cloudinary if available
  (async () => {
    try {
      const res = await fetch("/api/settings?key=hero_video_url");
      const { value } = await res.json();
      if (value && heroVideo) {
        heroVideo.src = value;
        heroVideo.load();
        if (!paused) heroVideo.play().catch(() => {});
      }
    } catch {}
  })();

  // Load gallery photos from Supabase
  (async () => {
    try {
      const res = await fetch("/api/gallery/list?limit=6");
      if (!res.ok) return;
      const photos: { url: string; categoria: string; alt_text: string | null }[] = await res.json();
      if (!photos.length) return;

      const items = document.querySelectorAll<HTMLElement>(".gal-item");
      photos.forEach((foto, i) => {
        if (!items[i] || !foto.url) return;
        const bg = items[i].querySelector(".gi-bg-img") as HTMLElement;
        if (!bg) return;
        const optimized = foto.url.replace("/upload/", "/upload/c_fill,w_800,h_800,q_auto,f_auto/");
        bg.style.backgroundImage = `url(${optimized})`;
        bg.style.backgroundSize = "cover";
        bg.style.backgroundPosition = "center";
        if (foto.categoria) items[i].dataset.cat = foto.categoria;
      });
    } catch {}
  })();
</script>

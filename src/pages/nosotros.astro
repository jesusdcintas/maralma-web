---
export const prerender = false;
import Layout from "../layouts/Layout.astro";
import { t as _t, type Lang } from "../utils/i18n";
import { loadCms, c as _c, imgStyle as _imgStyle } from "../utils/cms";

const lang = (Astro.currentLocale ?? "es") as Lang;
const t = (key: string) => _t(key, lang);
const localePath = (path: string) => lang === "en" ? `/en${path}` : path;
const cms = await loadCms();
const c = (key: string) => _c(cms, key, lang);
const img = (key: string) => _imgStyle(cms, key);
---

<Layout title={`${t("about.eyebrow")} · Maralma`} darkNav={true}>

  <!-- 1. HERO OSCURO -->
  <section class="page-hero">
    <div class="page-hero-bg"></div>
    <div class="page-hero-overlay"></div>
    <div class="page-hero-content">
      <span class="page-eyebrow" data-cms="about.eyebrow">{c("about.eyebrow")}</span>
    </div>
  </section>

  <!-- 2. JUAN — Split -->
  <section class="nosotros-section split-2">
    <div class="celda-texto">
      <h2 class="split-name" data-cms="about.juan.name">{c("about.juan.name")}</h2>
      <p class="split-role" data-cms="about.juan.role">{c("about.juan.role")}</p>
      <p class="split-tagline" data-cms="about.juan.tagline">&ldquo;{c("about.juan.tagline")}&rdquo;</p>
      <p class="split-body" data-cms="about.juan.bio">{c("about.juan.bio")}</p>
    </div>
    <div class="celda-foto" data-cms-img="nosotros.juan.foto" style={img("nosotros.juan.foto")}>
    </div>
  </section>

  <!-- 3. Separador — dos fotos lado a lado -->
  <section class="nosotros-section fotos-2">
    <div class="celda-foto" data-cms-img="nosotros.sep1.foto_izq" style={img("nosotros.sep1.foto_izq")}></div>
    <div class="celda-foto" data-cms-img="nosotros.sep1.foto_der" style={img("nosotros.sep1.foto_der")}></div>
  </section>

  <!-- 4. MIRIAM — Split -->
  <section class="nosotros-section split-2">
    <div class="celda-texto">
      <h2 class="split-name" data-cms="about.miriam.name">{c("about.miriam.name")}</h2>
      <p class="split-role" data-cms="about.miriam.role">{c("about.miriam.role")}</p>
      <p class="split-tagline" data-cms="about.miriam.tagline">&ldquo;{c("about.miriam.tagline")}&rdquo;</p>
      <p class="split-body" data-cms="about.miriam.bio">{c("about.miriam.bio")}</p>
    </div>
    <div class="celda-foto" data-cms-img="nosotros.miriam.foto" style={img("nosotros.miriam.foto")}>
    </div>
  </section>

  <!-- 5. Separador — dos fotos lado a lado -->
  <section class="nosotros-section fotos-2">
    <div class="celda-foto" data-cms-img="nosotros.sep2.foto_izq" style={img("nosotros.sep2.foto_izq")}></div>
    <div class="celda-foto" data-cms-img="nosotros.sep2.foto_der" style={img("nosotros.sep2.foto_der")}></div>
  </section>

  <!-- 6. Separador — foto a sangre completa -->
  <section class="nosotros-section foto-1">
    <div class="celda-foto" data-cms-img="nosotros.sep3.foto" style={img("nosotros.sep3.foto")}></div>
  </section>

  <!-- 7. CODO CON CODO — Split -->
  <section class="nosotros-section split-2">
    <div class="celda-texto">
      <h2 class="split-title" data-cms="about.juntos.title">{c("about.juntos.title")}</h2>
      <p class="split-body" data-cms="about.juntos.body">{c("about.juntos.body")}</p>
    </div>
    <div class="celda-foto" data-cms-img="nosotros.juntos.foto" style={img("nosotros.juntos.foto")}>
    </div>
  </section>

  <!-- 8. Frase separadora -->
  <section class="phrase-sep bg-crema">
    <p class="phrase-text" data-cms="about.phrase1"><em>{c("about.phrase1")}</em></p>
  </section>

  <!-- 9. QUE SOMOS — Split -->
  <section class="nosotros-section split-2">
    <div class="celda-texto">
      <h2 class="split-title" data-cms="about.quesomos.title">{c("about.quesomos.title")}</h2>
      <p class="split-body" data-cms="about.quesomos.body">{c("about.quesomos.body")}</p>
    </div>
    <div class="celda-foto" data-cms-img="nosotros.quesomos.foto" style={img("nosotros.quesomos.foto")}>
    </div>
  </section>

  <!-- 10. Separador — dos fotos lado a lado -->
  <section class="nosotros-section fotos-2">
    <div class="celda-foto" data-cms-img="nosotros.sep4.foto_izq" style={img("nosotros.sep4.foto_izq")}></div>
    <div class="celda-foto" data-cms-img="nosotros.sep4.foto_der" style={img("nosotros.sep4.foto_der")}></div>
  </section>

  <!-- 11. Solo realizamos una boda por dia — Split -->
  <section class="nosotros-section split-2">
    <div class="celda-texto">
      <p class="split-highlight" data-cms="about.unboda.text">{c("about.unboda.text")}</p>
    </div>
    <div class="celda-foto" data-cms-img="nosotros.unboda.foto" style={img("nosotros.unboda.foto")}>
    </div>
  </section>

  <!-- 12. Frase separadora -->
  <section class="phrase-sep bg-crema">
    <p class="phrase-text" data-cms="about.phrase2"><em>{c("about.phrase2")}</em></p>
  </section>

  <!-- 13. Separador — foto a sangre completa -->
  <section class="nosotros-section foto-1">
    <div class="celda-foto" data-cms-img="nosotros.sep5.foto" style={img("nosotros.sep5.foto")}></div>
  </section>

  <!-- 14. COMO HACEMOS CADA MENU — Split -->
  <section class="nosotros-section split-2">
    <div class="celda-texto">
      <h2 class="split-title" data-cms="about.comohacemos.title">{c("about.comohacemos.title")}</h2>
      <p class="split-body" data-cms="about.comohacemos.body">{c("about.comohacemos.body")}</p>
    </div>
    <div class="celda-foto" data-cms-img="nosotros.comohacemos.foto" style={img("nosotros.comohacemos.foto")}>
    </div>
  </section>

  <!-- 15. Continuacion COMO HACEMOS — Split -->
  <section class="nosotros-section split-2">
    <div class="celda-texto">
      <p class="split-body" data-cms="about.comohacemos2.body">{c("about.comohacemos2.body")}</p>
    </div>
    <div class="celda-foto" data-cms-img="nosotros.comohacemos2.foto" style={img("nosotros.comohacemos2.foto")}>
    </div>
  </section>

  <!-- 16. FILOSOFIA — Split -->
  <section class="nosotros-section split-2">
    <div class="celda-texto">
      <h2 class="split-title" data-cms="about.filosofia.title">{c("about.filosofia.title")}</h2>
      <p class="split-body" data-cms="about.filosofia.body">{c("about.filosofia.body")}</p>
      <p class="split-emphasis" data-cms="about.filosofia.emphasis"><em>{c("about.filosofia.emphasis")}</em></p>
    </div>
    <div class="celda-foto" data-cms-img="nosotros.filosofia.foto" style={img("nosotros.filosofia.foto")}>
    </div>
  </section>

  <!-- 17. EQUIPO — Split -->
  <section class="nosotros-section split-2">
    <div class="celda-texto">
      <h2 class="split-title" data-cms="about.equipo.title">{c("about.equipo.title")}</h2>
      <p class="split-tagline" data-cms="about.equipo.tagline">&ldquo;{c("about.equipo.tagline")}&rdquo;</p>
      <p class="split-body" data-cms="about.equipo.body">{c("about.equipo.body")}</p>
    </div>
    <div class="celda-foto" data-cms-img="nosotros.equipo.foto" style={img("nosotros.equipo.foto")}>
    </div>
  </section>

  <!-- 18. Separador — dos fotos lado a lado -->
  <section class="nosotros-section fotos-2">
    <div class="celda-foto" data-cms-img="nosotros.sep6.foto_izq" style={img("nosotros.sep6.foto_izq")}></div>
    <div class="celda-foto" data-cms-img="nosotros.sep6.foto_der" style={img("nosotros.sep6.foto_der")}></div>
  </section>

  <!-- 19. Separador — tres fotos en fila -->
  <section class="nosotros-section fotos-3">
    <div class="celda-foto" data-cms-img="nosotros.sep7.foto1" style={img("nosotros.sep7.foto1")}></div>
    <div class="celda-foto" data-cms-img="nosotros.sep7.foto2" style={img("nosotros.sep7.foto2")}></div>
    <div class="celda-foto" data-cms-img="nosotros.sep7.foto3" style={img("nosotros.sep7.foto3")}></div>
  </section>

  <!-- 20. Frase final — fondo negro -->
  <section class="phrase-sep bg-negro">
    <p class="phrase-text phrase-white" data-cms="about.phraseFinal"><em>{c("about.phraseFinal")}</em></p>
  </section>

  <!-- 21. CTA final -->
  <section class="contact-cta">
    <p class="cta-eyebrow reveal" data-cms="about.cta.eyebrow">{c("about.cta.eyebrow")}</p>
    <h2 class="cta-title reveal" data-cms="about.cta.title">{c("about.cta.title")}</h2>
    <p class="cta-body reveal" data-cms="about.cta.body">{c("about.cta.body")}</p>
    <a href={localePath("/contacto")} class="btn-dark reveal" data-cms="about.cta.button">{c("about.cta.button")} &rarr;</a>
  </section>

</Layout>

<style>
  /* HERO */
  .page-hero {
    position: relative; min-height: 50vh;
    display: flex; align-items: center;
    overflow: hidden; background: var(--color-negro);
  }
  .page-hero-bg {
    position: absolute; inset: 0;
    background: linear-gradient(160deg, #0a1820 0%, #1e3a4f 45%, #2d5169 100%);
  }
  .page-hero-overlay {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 60% 80% at 80% 50%, rgba(168,196,200,0.07) 0%, transparent 60%);
  }
  .page-hero-content {
    position: relative; z-index: 2;
    padding: 180px 60px 100px; max-width: 680px;
  }
  .page-eyebrow {
    font-size: 10px; letter-spacing: 0.24em; text-transform: uppercase;
    color: var(--color-azul-claro); display: block;
    animation: fadeUp 1s ease 0.3s both;
  }

  /* NOSOTROS SECTIONS — unified 90vh grid */
  .nosotros-section {
    display: grid;
    min-height: 90vh;
  }
  .nosotros-section.split-2 { grid-template-columns: 1fr 1fr; }
  .nosotros-section.fotos-2 { grid-template-columns: 1fr 1fr; }
  .nosotros-section.fotos-3 { grid-template-columns: 1fr 1fr 1fr; }
  .nosotros-section.foto-1  { grid-template-columns: 1fr; }

  .nosotros-section .celda-foto {
    position: relative; overflow: hidden;
    min-height: 90vh;
    background: var(--color-crema);
    background-size: cover; background-position: center;
  }

  .nosotros-section .celda-texto {
    min-height: 90vh;
    display: flex; flex-direction: column; justify-content: center;
    padding: 80px 70px;
    background: var(--color-blanco);
  }

  .split-name {
    font-family: var(--font-serif);
    font-size: clamp(48px, 5vw, 72px); font-weight: 300;
    color: var(--color-azul); letter-spacing: 0.06em;
    margin-bottom: 12px; line-height: 1;
  }
  .split-role {
    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--color-texto-suave); margin-bottom: 24px;
    border-left: 2px solid var(--color-azul-claro); padding-left: 12px;
  }
  .split-tagline {
    font-family: var(--font-serif); font-size: 18px; font-style: italic;
    color: var(--color-azul); margin-bottom: 24px; line-height: 1.5;
  }
  .split-title {
    font-family: var(--font-serif);
    font-size: clamp(28px, 3.5vw, 44px); font-weight: 300;
    color: var(--color-azul); margin-bottom: 24px; line-height: 1.15;
  }
  .split-body {
    font-size: 15px; font-weight: 300;
    color: var(--color-texto-suave); line-height: 1.9;
  }
  .split-highlight {
    font-family: var(--font-serif);
    font-size: clamp(24px, 3vw, 36px); font-weight: 300;
    color: var(--color-azul); line-height: 1.4;
  }
  .split-emphasis {
    font-family: var(--font-serif); font-size: 16px;
    color: var(--color-azul); margin-top: 20px; line-height: 1.7;
  }
  /* PHRASE SEPARATORS */
  .phrase-sep {
    padding: 100px 60px; text-align: center;
  }
  .bg-crema { background: var(--color-crema); }
  .bg-negro { background: var(--color-negro); }
  .phrase-text {
    font-family: var(--font-serif);
    font-size: clamp(24px, 3.5vw, 42px); font-weight: 300;
    color: var(--color-azul); line-height: 1.4;
    max-width: 700px; margin: 0 auto;
  }
  .phrase-white { color: var(--color-blanco); }

  /* CTA */
  .contact-cta {
    background: var(--color-blanco); padding: 100px 60px; text-align: center;
  }
  .cta-eyebrow {
    font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--color-texto-suave); margin-bottom: 20px;
  }
  .cta-title {
    font-family: var(--font-serif); font-size: clamp(32px, 4vw, 52px);
    font-weight: 300; color: var(--color-azul); margin-bottom: 20px; line-height: 1.1;
  }
  .cta-body {
    font-size: 14px; font-weight: 300; color: var(--color-texto-suave);
    max-width: 440px; margin: 0 auto 40px; line-height: 1.9;
  }
  .btn-dark {
    display: inline-block; font-family: var(--font-sans);
    font-size: 11px; font-weight: 500; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--color-blanco); background: var(--color-azul);
    padding: 14px 32px; text-decoration: none; transition: background 0.3s;
  }
  .btn-dark:hover { background: var(--color-azul-medio); }

  /* REVEAL */
  .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.8s ease, transform 0.8s ease; }
  .reveal.visible { opacity: 1; transform: none; }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .page-hero-content { padding: 120px 24px 60px; }
    .nosotros-section { grid-template-columns: 1fr; min-height: auto; }
    .nosotros-section .celda-foto { min-height: 60vw; }
    .nosotros-section .celda-texto { min-height: auto; padding: 48px 24px; }
    .phrase-sep { padding: 60px 24px; }
    .contact-cta { padding: 60px 24px; }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: none; }
  }
</style>

---
import Layout from "../layouts/Layout.astro";
import { t } from "../utils/i18n";
import { loadCms } from "../utils/cms";

const cms = await loadCms();
---

<Layout title={`${t("gallery.eyebrow")} · Maralma`} description="Descubre nuestros eventos, platos y montajes. Galería fotográfica de Maralma catering.">

  <!-- PAGE HERO -->
  <div class="page-hero">
    <div class="page-hero-content">
      <span class="page-eyebrow" data-cms="gallery.eyebrow">{cms.text["gallery.eyebrow"] || "Galería"}</span>
      <h1 class="page-title" data-cms="gallery.title">{cms.text["gallery.title"] || "Momentos que"}<br/><em>{cms.text["gallery.title"] ? "" : "hablan solos."}</em></h1>
      <p class="page-subtitle" data-cms="gallery.subtitle">{cms.text["gallery.subtitle"] || "Cada imagen es un recuerdo de un evento único. Nuestro trabajo, en acción."}</p>
    </div>
  </div>

  <!-- EVENTS GALLERY -->
  <section class="gallery">
    <div class="section-header reveal">
      <h2 class="section-title">Nuestros eventos</h2>
      <span class="section-eyebrow">Explora por categoría</span>
    </div>

    <div class="gallery-filters reveal">
      <button class="gf-btn active" data-tipo="all">Todos</button>
      <button class="gf-btn" data-tipo="boda">Bodas</button>
      <button class="gf-btn" data-tipo="corporativo">Corporativo</button>
      <button class="gf-btn" data-tipo="privado">Privados</button>
    </div>

    <div class="events-grid reveal" id="eventsGrid">
      <p class="events-loading" id="eventsLoading">Cargando eventos…</p>
    </div>
    <p class="events-empty hidden" id="eventsEmpty">Próximamente publicaremos nuestros eventos.</p>
  </section>

  <!-- CTA -->
  <section class="gallery-cta">
    <p class="cta-eyebrow reveal" data-cms="gallery.cta_eyebrow">{cms.text["gallery.cta_eyebrow"] || "¿Te gusta lo que ves?"}</p>
    <h2 class="cta-title reveal reveal-delay-1" data-cms="gallery.cta_title">{cms.text["gallery.cta_title"] || "Hagamos algo"}<br/>{cms.text["gallery.cta_title"] ? "" : "así de bonito"}<br/><em>{cms.text["gallery.cta_title"] ? "" : "para ti."}</em></h2>
    <a href="/contacto" class="btn-dark reveal reveal-delay-2">Ponerse en contacto →</a>
  </section>

</Layout>

<style>
  .page-hero {
    background: var(--color-azul); padding: 160px 60px 80px;
    position: relative; overflow: hidden;
  }
  .page-hero::after {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse 60% 80% at 80% 50%, rgba(168,196,200,0.07) 0%, transparent 60%);
  }
  .page-hero-content { position: relative; z-index: 1; max-width: 600px; }
  .page-eyebrow {
    font-size: 10px; letter-spacing: 0.24em; text-transform: uppercase;
    color: var(--color-azul-claro); margin-bottom: 20px; display: block;
  }
  .page-title {
    font-family: var(--font-serif); font-size: clamp(44px, 6vw, 80px);
    font-weight: 300; color: var(--color-blanco); line-height: 0.95;
    letter-spacing: -0.01em; margin-bottom: 24px;
  }
  .page-title em { font-style: italic; color: var(--color-azul-claro); }
  .page-subtitle {
    font-family: var(--font-serif); font-style: italic; font-size: 18px;
    font-weight: 300; color: rgba(253,252,250,0.55); line-height: 1.7;
  }

  /* GALLERY SECTION */
  .gallery { background: var(--color-negro); padding: 100px 60px; }
  .gallery .section-header {
    display: flex; align-items: baseline; justify-content: space-between;
    margin-bottom: 50px; border-bottom: 0.5px solid rgba(253,252,250,0.1); padding-bottom: 24px;
  }
  .gallery .section-title {
    font-family: var(--font-serif); font-size: clamp(32px, 4vw, 52px);
    font-weight: 300; color: var(--color-blanco); letter-spacing: -0.01em;
  }
  .gallery .section-eyebrow {
    font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase;
    color: rgba(253,252,250,0.4);
  }

  .gallery-filters {
    display: flex; gap: 6px; margin-bottom: 50px; flex-wrap: wrap;
  }
  .gf-btn {
    font-family: var(--font-sans); font-size: 10px; font-weight: 500;
    letter-spacing: 0.15em; text-transform: uppercase;
    background: transparent; border: 0.5px solid rgba(253,252,250,0.15);
    color: rgba(253,252,250,0.5); padding: 10px 22px; cursor: pointer;
    transition: all 0.3s;
  }
  .gf-btn:hover, .gf-btn.active {
    background: var(--color-blanco); color: var(--color-negro);
    border-color: var(--color-blanco);
  }

  /* EVENTS GRID */
  .events-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .events-loading, .events-empty {
    grid-column: 1 / -1; text-align: center; font-size: 13px;
    color: rgba(253,252,250,0.4); padding: 60px 0;
  }
  .hidden { display: none !important; }

  .event-card {
    position: relative; overflow: hidden; cursor: pointer;
    background: rgba(253,252,250,0.03);
    border: 0.5px solid rgba(253,252,250,0.06);
    transition: border-color 0.3s, transform 0.3s;
    text-decoration: none; display: block;
  }
  .event-card:hover {
    border-color: rgba(253,252,250,0.15);
    transform: translateY(-4px);
  }
  .event-card-cover {
    aspect-ratio: 3/2; overflow: hidden;
    background: linear-gradient(135deg, #1e3a4f, #2d5169);
  }
  .event-card-cover img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform 0.6s ease;
  }
  .event-card:hover .event-card-cover img { transform: scale(1.06); }
  .event-card-body { padding: 22px 20px; }
  .event-card-tipo {
    font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--color-azul-claro); margin-bottom: 8px; display: block;
  }
  .event-card-title {
    font-family: var(--font-serif); font-size: 22px; font-weight: 300;
    color: var(--color-blanco); line-height: 1.2; margin-bottom: 4px;
  }
  .event-card-subtitle {
    font-family: var(--font-serif); font-style: italic; font-size: 14px;
    font-weight: 300; color: rgba(253,252,250,0.45); margin-bottom: 12px;
  }
  .event-card-meta {
    font-size: 11px; color: rgba(253,252,250,0.35);
    display: flex; gap: 12px; flex-wrap: wrap;
  }

  /* CTA */
  .gallery-cta {
    background: var(--color-crema); padding: 100px 60px; text-align: center;
  }
  .cta-eyebrow {
    font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--color-texto-suave); margin-bottom: 20px;
  }
  .cta-title {
    font-family: var(--font-serif); font-size: clamp(32px, 4vw, 52px);
    font-weight: 300; color: var(--color-azul); margin-bottom: 40px; line-height: 1.1;
  }
  .cta-title em { font-style: italic; color: var(--color-azul-claro); }
  .btn-dark {
    display: inline-block; font-family: var(--font-sans);
    font-size: 11px; font-weight: 500; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--color-blanco); background: var(--color-azul);
    padding: 14px 32px; text-decoration: none;
    transition: background 0.3s;
  }
  .btn-dark:hover { background: var(--color-azul-medio); }

  @media (max-width: 768px) {
    .page-hero { padding: 120px 24px 60px; }
    .gallery { padding: 60px 24px; }
    .events-grid { grid-template-columns: 1fr; }
    .gallery-cta { padding: 60px 24px; }
    .gallery .section-header { flex-direction: column; gap: 8px; }
  }
  @media (min-width: 769px) and (max-width: 1024px) {
    .events-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<script>
  interface EventData {
    id: string;
    titulo: string;
    subtitulo: string | null;
    tipo: string;
    fecha: string | null;
    ubicacion: string | null;
    cover_url: string | null;
    slug: string;
  }

  const grid = document.getElementById("eventsGrid") as HTMLDivElement;
  const loading = document.getElementById("eventsLoading") as HTMLElement;
  const empty = document.getElementById("eventsEmpty") as HTMLElement;
  const filterBtns = document.querySelectorAll(".gf-btn");
  let events: EventData[] = [];

  function cloudinaryFill(url: string, w: number, h: number): string {
    return url.replace("/upload/", `/upload/c_fill,w_${w},h_${h},q_auto,f_auto/`);
  }

  function tipoLabel(tipo: string): string {
    if (tipo === "boda") return "Boda";
    if (tipo === "corporativo") return "Corporativo";
    return "Privado";
  }

  function renderEvents(filter: string) {
    grid.querySelectorAll(".event-card").forEach((c) => c.remove());
    const filtered = filter === "all" ? events : events.filter((e) => e.tipo === filter);

    if (!filtered.length) {
      empty.classList.remove("hidden");
      return;
    }
    empty.classList.add("hidden");

    for (const ev of filtered) {
      const card = document.createElement("a");
      card.className = "event-card";
      card.href = "/galeria/" + ev.slug;

      const coverHtml = ev.cover_url
        ? `<img src="${cloudinaryFill(ev.cover_url, 640, 426)}" alt="${ev.titulo}" loading="lazy" />`
        : "";

      const fecha = ev.fecha
        ? new Date(ev.fecha).toLocaleDateString("es-ES", { day: "numeric", month: "long", year: "numeric" })
        : "";

      card.innerHTML =
        `<div class="event-card-cover">${coverHtml}</div>` +
        `<div class="event-card-body">` +
          `<span class="event-card-tipo">${tipoLabel(ev.tipo)}</span>` +
          `<h3 class="event-card-title">${escapeHtml(ev.titulo)}</h3>` +
          (ev.subtitulo ? `<p class="event-card-subtitle">${escapeHtml(ev.subtitulo)}</p>` : "") +
          `<div class="event-card-meta">` +
            (fecha ? `<span>${fecha}</span>` : "") +
            (ev.ubicacion ? `<span>${escapeHtml(ev.ubicacion)}</span>` : "") +
          `</div>` +
        `</div>`;

      grid.appendChild(card);
    }
  }

  function escapeHtml(s: string): string {
    return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
  }

  // Load events
  async function init() {
    try {
      const res = await fetch("/api/admin/events");
      if (!res.ok) throw new Error("Fetch failed");
      events = await res.json();
      loading.classList.add("hidden");
      renderEvents("all");
    } catch {
      loading.textContent = "Error al cargar eventos.";
    }
  }

  // Filters
  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      filterBtns.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      renderEvents(btn.getAttribute("data-tipo") || "all");
    });
  });

  init();
</script>
